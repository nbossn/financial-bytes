# ============================================================
# financial-bytes — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# massive.com API
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_BASE_URL=https://api.massive.com

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/financial_bytes

# Email (Gmail SMTP)
EMAIL_RECIPIENT=your@email.com
EMAIL_FROM=your@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Newsletter Settings
NEWSLETTER_TIMEZONE=America/New_York
NEWSLETTER_SEND_TIME=07:20
PIPELINE_START_TIME=05:00

# Portfolio
PORTFOLIO_CSV_PATH=portfolio.csv

# GitHub (for fullstack agent newsletter commits)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=nbossn/financial-bytes

# Optional: Search fallback
# SERPAPI_KEY=your_serpapi_key_here
# DUCKDUCKGO_MAX_RESULTS=5

# Scraper settings
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
MAX_ARTICLES_PER_TICKER=15
ARTICLE_LOOKBACK_HOURS=24

# Parallelism / rate-limit tuning
# MAX_PARALLEL_TICKERS: Selenium browser instances for scraping. Max 3 on typical VPS (RAM limit).
MAX_PARALLEL_TICKERS=3
# MAX_PARALLEL_ANALYSTS: Concurrent claude -p (Haiku) subprocess calls.
#   Claude Code Pro/Max plan: safe at 5-8.  Standard Pro plan: keep at 3.
#   15 tickers x 5 concurrent = 3 rounds x ~10s = ~30s for analyst phase.
MAX_PARALLEL_ANALYSTS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/financial_bytes.log

# Multi-portfolio config path (default: portfolios.json in project root)
# PORTFOLIOS_CONFIG=portfolios.json
